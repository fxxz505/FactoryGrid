{
  "name": "factorygrid",
  "version": "1.0.0",
  "description": "A modular automation factory simulator built with Vue, TypeScript, Canvas, and a deterministic simulation engine.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.vue"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.30.1",
    "eslint-plugin-vue": "^10.3.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^1.6.1",
    "vue-tsc": "^2.2.10"
  }
}
